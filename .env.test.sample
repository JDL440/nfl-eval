# NFL Lab - Local Environment (TEMPLATE)
# Copy to .env.test and fill in real values

# LLM Provider: lmstudio | copilot | mock
LLM_PROVIDER=copilot-cli
LMSTUDIO_URL=

# Substack Publishing (see .env.sample for setup instructions)
SUBSTACK_TOKEN=YOUR_SUBSTACK_SESSION_TOKEN_HERE
SUBSTACK_PUBLICATION_URL=https://your-pub.substack.com
SUBSTACK_STAGE_URL=https://your-stage-pub.substack.com

# Google Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Notes API
NOTES_ENDPOINT_PATH=/api/v1/comment/feed
NOTES_PAYLOAD_SHAPE=prosemirror

# Twitter/X API (article promotion)
# Setup: https://developer.x.com/portal/dashboard
TWITTER_API_KEY=YOUR_TWITTER_API_KEY_HERE
TWITTER_API_SECRET=YOUR_TWITTER_API_SECRET_HERE
TWITTER_ACCESS_TOKEN=YOUR_TWITTER_ACCESS_TOKEN_HERE
TWITTER_ACCESS_TOKEN_SECRET=YOUR_TWITTER_ACCESS_TOKEN_SECRET_HERE
CLIENT_ID=YOUR_CLIENT_ID_HERE

COPILOT_MODEL=claude-sonnet-4.5

SUBSTACK_TARGET=stage
