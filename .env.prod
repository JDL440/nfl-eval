# NFL Lab — Environment Variables

# ─── LLM Provider / Local LM Studio ───────────────────────────────────────────
#
# Set LMSTUDIO_MODEL to a loaded chat model ID, or leave blank for auto-detect.
#
LLM_PROVIDER=lmstudio
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-35b-a3b

# ─── GitHub Copilot CLI (optional) ─────────────────────────────────────────────
#
# Default behavior is text-only. Set COPILOT_CLI_MODE=article-tools to allow the
# guarded Copilot CLI surface (web fetch + repo MCP).
#
# Legacy compatibility flags:
#   - COPILOT_CLI_ENABLE_TOOLS=1
#   - COPILOT_ENABLE_TOOLS=1
# These still enable article-tools mode, but prefer COPILOT_CLI_MODE going
# forward so the active mode is explicit.
#
# In article-tools mode:
#   - web fetch stays enabled unless COPILOT_CLI_WEB_SEARCH=0 or
#     COPILOT_ENABLE_WEB_FETCH=0
#   - repo MCP stays enabled unless COPILOT_ENABLE_REPO_MCP=0
#   - session reuse stays off unless COPILOT_CLI_SESSION_REUSE=1 or
#     COPILOT_ENABLE_SESSION_REUSE=1
#
COPILOT_MODEL=claude-sonnet-4.6
COPILOT_PATH=copilot
COPILOT_WORKING_DIRECTORY=.
COPILOT_EXTRA_FLAGS=
COPILOT_CLI_MODE=article-tools
COPILOT_CLI_WEB_SEARCH=1
COPILOT_ENABLE_WEB_FETCH=1
COPILOT_ENABLE_REPO_MCP=1
COPILOT_CLI_MCP_CONFIG=.copilot\mcp-config.json
COPILOT_CLI_SESSION_REUSE=1
COPILOT_ENABLE_SESSION_REUSE=1
COPILOT_CLI_ENABLE_TOOLS=0
COPILOT_ENABLE_TOOLS=0

# ─── Substack Publishing ──────────────────────────────────────────────────────
#
# Setup (one-time):
#   1. Log in to Substack in Chrome
#   2. Open DevTools → Application → Cookies → nfllabstage.substack.com (or your pub)
#   3. Copy the value of `substack.sid`
#   4. Paste it directly as SUBSTACK_TOKEN below
#
# If the token stops working (auth error), refresh it:
#   - Chrome cookies expire when you log out or after ~30 days
#   - Repeat steps 1–4 above with a fresh login
#
SUBSTACK_TOKEN=eyJzdWJzdGFja19zaWQiOiJzOmFLckswc1Q3Y19IdnhCNE5DTFJoRnFDMFdBTHdFY0s4LmlPeUFtcVFPNU1pY0UzekQ4SXpjUHF1K05aYXcvdEJaOUV5L3N4bVZwR1EifQ==
SUBSTACK_PUBLICATION_URL=https://nfllab.substack.com
SUBSTACK_STAGE_URL=https://nfllabstage.substack.com

# ─── Dashboard Auth (optional) ────────────────────────────────────────────────
#
# Leave DASHBOARD_AUTH_MODE=off for local/tests when you want the dashboard open.
# Set DASHBOARD_AUTH_MODE=local in shared/public deployments to require login.
#
# Cookie security defaults:
#   - httpOnly
#   - SameSite=Lax
#   - Secure when NODE_ENV=production
#
DASHBOARD_AUTH_MODE=local
DASHBOARD_AUTH_USERNAME=operator
DASHBOARD_AUTH_PASSWORD=Cop1lot!bndaba
DASHBOARD_SESSION_COOKIE=nfl_lab_dashboard_session
DASHBOARD_SESSION_TTL_HOURS=24

