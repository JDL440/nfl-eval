{
  "mcpServers": {
    "nfl-eval-pipeline": {
      "command": "npx",
      "args": [
        "tsx",
        "src/cli.ts",
        "mcp"
      ],
      "cwd": "${workspaceFolder}"
    },
    "nfl-eval-local": {
      "command": "node",
      "args": [
        "mcp/server.mjs"
      ],
      "cwd": "${workspaceFolder}"
    }
  }
}
