{
  "name": "nfl-eval",
  "version": "1.0.0",
  "description": "> 47 AI agents analyze the NFL so you don't have to read 200 beat reporters. They argue with each other, and the best analysis wins.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard": "echo 'v1 dashboard archived — use v2:serve instead'",
    "dashboard:dev": "echo 'v1 dashboard archived — use v2:dev instead'",
    "mcp:server": "node mcp/server.mjs",
    "mcp:smoke": "node mcp/smoke-test.mjs",
    "v2:build": "tsc",
    "v2:dev": "tsx watch src/cli.ts serve",
    "v2:start": "node dist/cli.js serve",
    "v2:serve": "tsx src/cli.ts serve",
    "v2:init": "tsx src/cli.ts init",
    "v2:migrate": "tsx src/cli.ts migrate",
    "v2:status": "tsx src/cli.ts status",
    "v2:mcp": "tsx src/cli.ts mcp",
    "v2:test": "vitest run",
    "v2:test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JDL440/nfl-eval.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JDL440/nfl-eval/issues"
  },
  "homepage": "https://github.com/JDL440/nfl-eval#readme",
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@types/node": "^22.15.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.7.0",
    "vscode-jsonrpc": "^8.2.1",
    "zod": "^4.3.6"
  }
}
