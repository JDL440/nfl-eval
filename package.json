{
  "name": "nfl-eval-backend",
  "version": "1.0.0",
  "description": "BullMQ job queue for automated NFL article generation pipeline",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node scripts/job-processor.js",
    "queue:init": "node scripts/queue-init.js",
    "sweep": "node scripts/media-sweep.js",
    "test": "jest --coverage --testPathPattern=\"tests/(budget|integration|performance)\"",
    "test:mocks": "jest --coverage --testPathPattern=\"tests/(budget|integration|performance)\" --verbose",
    "test:unit-only": "jest tests/unit --verbose",
    "test:e2e": "jest tests/integration --verbose",
    "test:all": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "dev": "node --watch scripts/job-processor.js",
    "redis:local": "docker run -d -p 6379:6379 redis:latest"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "better-sqlite3": "^9.2.2",
    "bullmq": "^5.0.0",
    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "js-tiktoken": "^1.0.12",
    "node-schedule": "^2.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.3.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
