# Dashboard Configuration

# Use mock API for development (true) or real Backend API (false)
REACT_APP_USE_MOCK_API=true

# Backend API URL (used when REACT_APP_USE_MOCK_API=false)
REACT_APP_API_URL=http://localhost:3001/api

# Optional: Daily token budget limit (in dollars)
REACT_APP_TOKEN_BUDGET=1.30

# Optional: Budget alert threshold (percentage)
REACT_APP_BUDGET_ALERT_THRESHOLD=70
