# NFL Lab — Environment Variables

# ─── LLM Provider / Local LM Studio ───────────────────────────────────────────
#
# Use LM Studio for local model runs:
#   1. Start LM Studio's local server
#   2. Load a chat-capable model
#   3. Keep the URL at the server's OpenAI-compatible endpoint
#
# Leave LMSTUDIO_MODEL blank to auto-detect the first loaded non-embedding model.
#
LLM_PROVIDER=lmstudio
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=

# ─── Substack Publishing ──────────────────────────────────────────────────────
#
# Setup (one-time):
#   1. Log in to Substack in Chrome
#   2. Open DevTools → Application → Cookies → nfllabstage.substack.com (or your pub)
#   3. Copy the value of `substack.sid`
#   4. Paste it directly as SUBSTACK_TOKEN below
#
# If the token stops working (auth error), refresh it:
#   - Chrome cookies expire when you log out or after ~30 days
#   - Repeat steps 1–4 above with a fresh login
#
SUBSTACK_TOKEN=<paste substack.sid cookie value here>
SUBSTACK_PUBLICATION_URL=https://yourpub.substack.com
SUBSTACK_STAGE_URL=https://yourpubstage.substack.com

# ─── Dashboard Auth (optional) ────────────────────────────────────────────────
#
# Leave DASHBOARD_AUTH_MODE=off for local/tests when you want the dashboard open.
# Set DASHBOARD_AUTH_MODE=local in shared/public deployments to require login.
#
# Cookie security defaults:
#   - httpOnly
#   - SameSite=Lax
#   - Secure when NODE_ENV=production
#
DASHBOARD_AUTH_MODE=off
DASHBOARD_AUTH_USERNAME=operator
DASHBOARD_AUTH_PASSWORD=<strong-local-password>
DASHBOARD_SESSION_COOKIE=nfl_lab_dashboard_session
DASHBOARD_SESSION_TTL_HOURS=24

# ─── Google Gemini API (image generation) ────────────────────────────────────
#
# Setup (one-time):
#   1. Go to https://aistudio.google.com/apikey
#   2. Create an API key
#   3. Paste the key below
#
# Used by: .github/extensions/gemini-imagegen/extension.mjs
# Note: Imagen 4 requires a paid Google AI Studio account.
#       Gemini Flash works on the free tier.
#
GEMINI_API_KEY=<your-gemini-api-key>

# ─── Twitter/X API (article promotion) ───────────────────────────────────────
#
# Setup (one-time):
#   1. Go to https://developer.x.com/portal/dashboard
#   2. Create a project + app under the Free tier
#   3. Set "App permissions" to "Read and Write"
#   4. Under "Keys and Tokens", generate:
#      - Consumer Keys (API Key and Secret)
#      - Authentication Tokens → Access Token and Secret
#   5. Paste all four values below
#
# Rate limit: Free tier = 500 tweets/month (sufficient for NFL Lab)
#
TWITTER_API_KEY=<consumer key from X Developer Portal>
TWITTER_API_SECRET=<consumer secret from X Developer Portal>
TWITTER_ACCESS_TOKEN=<access token for your account>
TWITTER_ACCESS_TOKEN_SECRET=<access token secret for your account>
