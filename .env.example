# NFL Lab — Environment Variables

# ─── Substack Publishing ──────────────────────────────────────────────────────
#
# Setup (one-time):
#   1. Log in to Substack in Chrome
#   2. Open DevTools → Application → Cookies → nfllabstage.substack.com (or your pub)
#   3. Copy the value of `substack.sid` (only this cookie is needed)
#   4. Run this command to generate your token:
#        node -e "console.log(Buffer.from(JSON.stringify({ substack_sid: 'PASTE_YOUR_SID_VALUE_HERE' })).toString('base64'))"
#      Or in PowerShell:
#        $sid='PASTE_YOUR_SID_VALUE_HERE'; [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes(('{"substack_sid":"'+$sid+'"}')))
#   5. Paste the output as SUBSTACK_TOKEN below
#
# If the token stops working (auth error), refresh it:
#   - Chrome cookies expire when you log out or after ~30 days
#   - Repeat steps 1–5 above with a fresh login
#
SUBSTACK_TOKEN=<base64-encoded-json-token>
SUBSTACK_PUBLICATION_URL=https://yourpub.substack.com

# ─── Google Gemini API (image generation) ────────────────────────────────────
#
# Setup (one-time):
#   1. Go to https://aistudio.google.com/apikey
#   2. Create an API key
#   3. Paste the key below
#
# Used by: .github/extensions/gemini-imagegen/extension.mjs
# Note: Imagen 4 requires a paid Google AI Studio account.
#       Gemini Flash works on the free tier.
#
GEMINI_API_KEY=<your-gemini-api-key>
