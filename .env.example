# BullMQ Queue Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Anthropic API
ANTHROPIC_API_KEY=

# Google Gemini API (for image generation via Imagen 3)
#
# Setup (one-time):
#   1. Go to https://ai.google.dev/gemini-api/docs/get-api-key
#   2. Create an API key in Google AI Studio
#   3. Paste the key below
#
# Used by: generate_article_images extension (Imagen 3 → content/images/{slug}/)
# Requires a paid Google AI Studio account for Imagen 3 access.
GEMINI_API_KEY=

# Substack Publishing
#
# Setup (one-time):
#   1. Log in to Substack in Chrome
#   2. Open DevTools → Application → Cookies → https://substack.com
#   3. Copy the values of `substack.sid` and `connect.sid`
#   4. Run this command to generate your token:
#        node -e "console.log(Buffer.from(JSON.stringify({ substack_sid: 'YOUR_SID', connect_sid: 'YOUR_CONNECT_SID' })).toString('base64'))"
#   5. Paste the output as SUBSTACK_TOKEN below
#
# Alternative: use ~/.config/postcli/.env (same format, shared with postcli tools)
SUBSTACK_TOKEN=REDACTED_SUBSTACK_TOKEN
SUBSTACK_PUBLICATION_URL=https://nfllabstage.substack.com

# Job Processing
NODE_ENV=development
LOG_LEVEL=info
