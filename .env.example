# NFL Lab — Environment Variables

# ─── Substack Publishing ──────────────────────────────────────────────────────
#
# Setup (one-time):
#   1. Log in to Substack in Chrome
#   2. Open DevTools → Application → Cookies → https://substack.com
#   3. Copy the values of `substack.sid` and `connect.sid`
#   4. Run this command to generate your token:
#        node -e "console.log(Buffer.from(JSON.stringify({ substack_sid: 'YOUR_SID', connect_sid: 'YOUR_CONNECT_SID' })).toString('base64'))"
#   5. Paste the output as SUBSTACK_TOKEN below
#
SUBSTACK_TOKEN=<base64-encoded-json-token>
SUBSTACK_PUBLICATION_URL=https://yourpub.substack.com

# ─── Google Gemini API (image generation) ────────────────────────────────────
#
# Setup (one-time):
#   1. Go to https://aistudio.google.com/apikey
#   2. Create an API key
#   3. Paste the key below
#
# Used by: .github/extensions/gemini-imagegen/extension.mjs
# Note: Imagen 4 requires a paid Google AI Studio account.
#       Gemini Flash works on the free tier.
#
GEMINI_API_KEY=<your-gemini-api-key>
